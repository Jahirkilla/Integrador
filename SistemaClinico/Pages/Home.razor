    private static List<Cita> citasPorDiaCardiología = new List<Cita>
{
    new Cita { Fecha = DateTime.Now.AddDays(-3).ToString("dd-MM-yyyy"), Cantidad = 8 },
    new Cita { Fecha = DateTime.Now.AddDays(-2).ToString("dd-MM-yyyy"), Cantidad = 14 },
    new Cita { Fecha = DateTime.Now.AddDays(-1).ToString("dd-MM-yyyy"), Cantidad = 25 },
    new Cita { Fecha = DateTime.Now.AddDays(0).ToString("dd-MM-yyyy"), Cantidad = 19 }
};

    private static List<Cita> citasPorDiaPediatría = new List<Cita>
{
    new Cita { Fecha = DateTime.Now.AddDays(-3).ToString("dd-MM-yyyy"), Cantidad = 15 },
    new Cita { Fecha = DateTime.Now.AddDays(-2).ToString("dd-MM-yyyy"), Cantidad = 7 },
    new Cita { Fecha = DateTime.Now.AddDays(-1).ToString("dd-MM-yyyy"), Cantidad = 16 },
    new Cita { Fecha = DateTime.Now.AddDays(0).ToString("dd-MM-yyyy"), Cantidad = 13 }
};

    private static List<Cita> citasPorDiaGinecología = new List<Cita>
{
    new Cita { Fecha = DateTime.Now.AddDays(-3).ToString("dd-MM-yyyy"), Cantidad = 9 },
    new Cita { Fecha = DateTime.Now.AddDays(-2).ToString("dd-MM-yyyy"), Cantidad = 17 },
    new Cita { Fecha = DateTime.Now.AddDays(-1).ToString("dd-MM-yyyy"), Cantidad = 12 },
    new Cita { Fecha = DateTime.Now.AddDays(0).ToString("dd-MM-yyyy"), Cantidad = 13 }
};

    private static List<Cita> citasPorDiaMedicinaGeneral = new List<Cita>
{
    new Cita { Fecha = DateTime.Now.AddDays(-3).ToString("dd-MM-yyyy"), Cantidad = 15 },
    new Cita { Fecha = DateTime.Now.AddDays(-2).ToString("dd-MM-yyyy"), Cantidad = 10 },
    new Cita { Fecha = DateTime.Now.AddDays(-1).ToString("dd-MM-yyyy"), Cantidad = 8 },
    new Cita { Fecha = DateTime.Now.AddDays(0).ToString("dd-MM-yyyy"), Cantidad = 14 }};


    private List<Especialidad> pacientesPorEspecialidad = new List<Especialidad>
    {
        new Especialidad { Especialidadd = "Cardiología", Cantidad = citasPorDiaCardiología.Sum(x => x.Cantidad) },
        new Especialidad { Especialidadd = "Pediatría", Cantidad = citasPorDiaPediatría.Sum(x => x.Cantidad) },
        new Especialidad { Especialidadd = "Ginecología", Cantidad = citasPorDiaGinecología.Sum(x => x.Cantidad) },
        new Especialidad { Especialidadd = "Medicina General", Cantidad = citasPorDiaMedicinaGeneral.Sum(x => x.Cantidad) }
    };

    private void IrAGestion()
    {
        // Lógica para redirigir al panel de gestión
        NavigationManager.NavigateTo("/gestion");
    }

    // Clases para los datos de ejemplo
    public class Cita
    {
        public string Fecha { get; set; }
        public int Cantidad { get; set; }
    }

    public class Especialidad
    {
        public string Especialidadd { get; set; }
        public int Cantidad { get; set; }
    }
}
