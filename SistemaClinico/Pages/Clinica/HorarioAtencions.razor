@page "/horario-atencions"
@inject HorarioAtencionService horarioAtencionService
@inject DiaSemanaService diaSemanaService
@inject HoraService horaService
@inject MedicoService medicoService

<h3>Gestión de Horario de Atenciones</h3>

<!-- Formulario para registrar un nuevo horario de atención -->
<div class="card p-3 mb-4">
	<h5>Registrar Horario Atencion</h5>

	<EditForm Model="nuevoHorarioAtencion" OnValidSubmit="GuardarHorarioAtencion">
		<DataAnnotationsValidator/>
		<ValidationSummary/>

		<div class="mb-2">
			<label>Estado</label>
			<InputText @bind-Value="nuevoHorarioAtencion.estado" class="form-control"/>
		</div>
		<div class="mb-2">
			<label>Fecha</label>
			<input type="date" @bind-value="nuevoHorarioAtencion.fecha" class="form-control"/>
		</div>
		<div class="mb-2">
			<label>Fecha Fin</label>
			<input type="date" @bind-value="nuevoHorarioAtencion.fechaFin" class="form-control"/>
		</div>
		<div class="mb-2">
			<label>Dia Semana</label>
			<InputSelect @bind-Value="nuevoHorarioAtencion.idDiaSemana" class="form-control">
				<option value="">Seleccionar Dia Semana</option>
				@foreach(var dia in diaSemanas)
				{
					<option value="@dia.idDiaSemana">@dia.nombreDiaSemana</option>
				}
			</InputSelect>
		</div>
		<div class="mb-2">
			<label>Hora</label>
			<InputSelect @bind-Value="nuevoHorarioAtencion.idHora" class="form-control">
				<option value="">Seleccionar Hora</option>
				@foreach(var hora in horas)
				{
					<option value="@hora.idHora">@hora.hora</option>
				}
			</InputSelect>
		</div>
		<div class="mb-2">
			<label>Medicos</label>
			<InputSelect @bind-Value="nuevoHorarioAtencion.idMedico" class="form-control">
				<option value="">Seleccionar Medico</option>
				@foreach(var medico in medicos)
				{
					<option value="@medico.idMedico">@medico.idMedico</option>
				}
			</InputSelect>
		</div>

		<button type="submit" class="btn btn-primary">Guardar</button>
	</EditForm>
</div>

<!-- Tabla para mostrar horario de atenciones -->
<div class="card p-3">
	<h5>Lista de Horario de Atenciones</h5>

	@if(horarioAtencions == null)
	{
		<p>Cargando...</p>
	}else if(horarioAtencions.Count == 0)
	{
		<p>No hay horario de atenciones registrados</p>
	}
	else
	{
		<table class="table table-striped">
			<thead>
				<tr>
					<th>Id Horario Atencion</th>
					<th>Estado</th>
					<th>Fecha</th>
					<th>Fecha Fin</th>
					<th>Dia Semana</th>
					<th>Hora</th>
					<th>Medico</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody>
				@foreach(var h in horarioAtencions)
				{
					<tr>
						<td>@h.idHorarioAtencion</td>
						<td>@h.estado</td>
						<td>@h.fecha</td>
						<td>@h.fechaFin</td>
						<td>@h.diaSemana?.nombreDiaSemana</td>
						<td>@h.hora?.hora</td>
						<td>@h.medico?.idMedico</td>
						<td>
							<button class="btn btn-danger btn-sm" @onclick="() => EliminarHorarioAtencion(h.idHorarioAtencion)">Eliminar</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	}
</div>

@code{
	private List<HorarioAtencion> horarioAtencions = new();
	private List<DiaSemana> diaSemanas = new();
	private List<Hora> horas = new();
	private List<Medico> medicos = new();
	private HorarioAtencion nuevoHorarioAtencion = new();

	protected override async Task OnInitializedAsync()
	{
		await CargarDiaSemanas();
		await CargarHorarioAtencions();
		await CargarHoras();
		await CargarMedicos();
	}

	private async Task CargarHorarioAtencions()
	{
		horarioAtencions = await horarioAtencionService.GetHorarioAtencions();
	}

	private async Task CargarDiaSemanas()
	{
		diaSemanas = await diaSemanaService.GetDiaSemanas();
	}

	private async Task CargarHoras()
	{
		horas = await horaService.GetHoras();
	}

	private async Task CargarMedicos()
	{
		medicos = await medicoService.GetMedicos();
	}

	private async Task GuardarHorarioAtencion()
	{
		var exito = await horarioAtencionService.AddHorarioAtencion(nuevoHorarioAtencion);
		if (exito)
		{
			nuevoHorarioAtencion = new HorarioAtencion();
			await CargarHorarioAtencions();
		}
	}

	private async Task EliminarHorarioAtencion(int id)
	{
		var exito = await horarioAtencionService.DeleteHorarioAtencion(id);
		if (exito)
		{
			await CargarHorarioAtencions();
		}
	}
}