@page "/medicos"
@inject MedicoService medicoService
@inject EmpleadoService empleadoService
@inject EspecialidadService especialidadService

<h3>Gestión de Médicos</h3>

<!-- Formulario para registrar un nuevo médico -->
<div class="card p-3 mb-4">
	<h5>Registrar Medico</h5>

	<EditForm Model="nuevoMedico" OnValidSubmit="GuardarMedico">
		<DataAnnotationsValidator />
		<ValidationSummary />

		<div class="mb-2">
			<label>Estado</label>
			<InputText @bind-Value="nuevoMedico.estado" class="form-control" />
		</div>
		<div class="mb-2">
			<label>Empleado</label>
			<InputSelect @bind-Value="nuevoMedico.idEmpleado" class="form-control">
				<option value="">Seleccionar Empleado</option>
				@foreach (var empleado in empleados)
				{
					<option value="@empleado.idEmpleado">@empleado.nombres</option>
				}
			</InputSelect>
		</div>
		<div class="mb-2">
			<label>Especialidad</label>
			<InputSelect @bind-Value="nuevoMedico.idEspecialidad" class="form-control">
				<option value="">Seleccionar Especialidad</option>
				@foreach (var especialidad in especialidads)
				{
					<option value="@especialidad.idEspecialidad">@especialidad.descripcion</option>
				}
			</InputSelect>
		</div>

		<button type="submit" class="btn btn-primary">Guardar</button>
	</EditForm>
</div>

<!-- Tabla para mostrar medicos -->
<div class="card p-3">
	<h5>Lista de Medicos</h5>

	@if (medicos == null)
	{
		<p>Cargando...</p>
	}
	else if (medicos.Count == 0)
	{
		<p>No hay medicos registrados</p>
	}
	else
	{
		<table class="table table-striped">
			<thead>
				<tr>
					<th>Id Medico</th>
					<th>Nombres</th>
					<th>Especialidad</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var m in medicos)
				{
					<tr>
						<td>@m.idMedico</td>
						<td>@m.empleado?.nombres</td>
						<td>@m.especialidad?.descripcion</td>
						<td>
							<button class="btn btn-danger btn-sm" @onclick="() => EliminarMedico(m.idMedico)">Eliminar</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	}
</div>

@code {
	private List<Medico> medicos = new();
	private List<SistemaClinico.Models.Clinica.Empleado> empleados = new();
	private List<Especialidad> especialidads = new();
	private Medico nuevoMedico = new();

	protected override async Task OnInitializedAsync()
	{
		await CargarEmpleados();
		await CargarEspecialidades();
		await CargarMedicos();
	}

	private async Task CargarEmpleados()
	{
		empleados = await empleadoService.GetEmpleados();
	}

	private async Task CargarEspecialidades()
	{
		especialidads = await especialidadService.GetEspecialidads();
	}

	private async Task CargarMedicos()
	{
		medicos = await medicoService.GetMedicos();
	}

	private async Task GuardarMedico()
	{
		var exito = await medicoService.AddMedico(nuevoMedico);
		if (exito)
		{
			nuevoMedico = new Medico();
			await CargarMedicos();
		}
	}

	private async Task EliminarMedico(int id)
	{
		var exito = await medicoService.DeleteMedico(id);
		if (exito)
		{
			await CargarMedicos();
		}
	}
}