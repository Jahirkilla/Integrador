@page "/horas"
@inject HoraService horaService

<h3>Gestión de Horas</h3>

<!-- Formulario para registrar una nueva hora -->
<div class="card p-3 mb-4">
	<h5>Registrar Hora</h5>
	<EditForm Model="nuevoHora" OnValidSubmit="GuardarHora">
		<DataAnnotationsValidator />
		<ValidationSummary />

		<div class="mb-2">
			<label>Hora</label>
			<InputText @bind-Value="nuevoHora.hora" class="form-control" />
		</div>

		<button type="submit" class="btn btn-primary">Guardar</button>
	</EditForm>
</div>

<!-- Tabla para mostrar horas -->
<div class="card p-3">
	<h5>Lista de Horas</h5>

	@if (horas == null)
	{
		<p>Cargando...</p>
	}
	else if (horas.Count == 0)
	{
		<p>No hay horas registradas</p>
	}
	else
	{
		<table class="table table-striped">
			<thead>
				<tr>
					<th>Id Hora</th>
					<th>Hora</th>
					<th>Acciones</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var h in horas)
				{
					<tr>
						<td>@h.idHora</td>
						<td>@h.hora</td>
						<td>
							<button class="btn btn-danger btn-sm" @onclick="() => EliminarHora(h.idHora)">Eliminar</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	}
</div>

@code {
	private List<Hora> horas = new();
	private Hora nuevoHora = new();

	protected override async Task OnInitializedAsync()
	{
		await CargarHoras();
	}

	private async Task CargarHoras()
	{
		horas = await horaService.GetHoras();
	}

	private async Task GuardarHora()
	{
		var exito = await horaService.AddHora(nuevoHora);
		if (exito)
		{
			nuevoHora = new Hora();
			await CargarHoras();
		}
	}

	private async Task EliminarHora(int id)
	{
		var exito = await horaService.DeleteHora(id);
		if (exito)
		{
			await CargarHoras();
		}
	}
}