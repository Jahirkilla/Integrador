@layout LoginLayout
@page "/login"
@using SistemaClinico.Auth
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService
@inject TooltipService TooltipService
@inject NotificationService NotificationService
@inject NavigationManager navigationManager
@inject ILoginService loginService

<PageTitle>Login</PageTitle>

@if (paginaBloqueada)
{
    <div class="alert alert-danger text-center mt-4">
        🚫 La página está bloqueada por demasiados intentos fallidos.<br />
        Recargue el navegador para volver a intentar.
    </div>
}
else
{
    <RadzenText Text="Login" TextStyle="Radzen.Blazor.TextStyle.H5" class="mb-4" TagName="Radzen.Blazor.TagName.H2" />

    <RadzenRow>
        <RadzenColumn SizeMD="12">
            <RadzenTemplateForm TItem="Model" Data=@model Submit=@OnSubmit InvalidSubmit=@OnInvalidSubmit>
                <RadzenStack Gap="1.5rem">
                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                        <RadzenColumn Size="12" SizeXS="4" SizeSM="12" SizeMD="4">
                            <RadzenLabel Text="Username" Component="Username" />
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeXS="8" SizeSM="12" SizeMD="8">
                            <RadzenTextBox style="display: block" Name="Username" Placeholder="Usuario..."
                                           @bind-Value=@model.Username class="rz-w-100" />
                            <RadzenDataAnnotationValidator Component="Username" Popup=@popup Style="position: absolute" />
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow AlignItems="AlignItems.Center" RowGap="0.25rem">
                        <RadzenColumn Size="12" SizeXS="4" SizeSM="12" SizeMD="4">
                            <RadzenLabel Text="Password" Component="Password" />
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeXS="8" SizeSM="12" SizeMD="8">
                            <RadzenPassword style="display: block" Name="Password" Placeholder="Contraseña..."
                                            @bind-Value=@model.Password class="rz-w-100" aria-label="enter password" />
                            <RadzenDataAnnotationValidator Component="Password" Popup=@popup Style="position: absolute" />
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow AlignItems="AlignItems.Center">
                        <RadzenColumn Size="12" Offset="0" SizeXS="8" OffsetXS="4" SizeSM="12" OffsetSM="0" SizeMD="8" OffsetMD="4">
                            <RadzenButton ButtonType="ButtonType.Submit" Text="Login"></RadzenButton>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenTemplateForm>
        </RadzenColumn>
    </RadzenRow>
}

@code {
    protected string redirectUrl;
    protected string error;
    protected string info;
    protected bool errorVisible;
    protected bool infoVisible;

    int intentosFallidos = 0;
    bool paginaBloqueada = false;

    protected override async Task OnInitializedAsync()
    {
        var query = System.Web.HttpUtility.ParseQueryString(
            new Uri(NavigationManager.ToAbsoluteUri(NavigationManager.Uri).ToString()).Query);

        error = query.Get("error");
        info = query.Get("info");
        redirectUrl = query.Get("redirectUrl");
        errorVisible = !string.IsNullOrEmpty(error);
        infoVisible = !string.IsNullOrEmpty(info);
    }

    class Model
    {
        [Required]
        [StringLength(15, MinimumLength = 3)]
        public string Username { get; set; }

        [Required]
        [StringLength(100, MinimumLength = 1)]
        [DataType(DataType.Password)]
        public string Password { get; set; }
    }

    bool popup;
    Model model = new Model();

    async void OnSubmit(Model model)
    {
        if (paginaBloqueada)
            return;

        // ✔ Usuarios válidos
        if ((model.Username == "jahir" && model.Password == "killa0195") ||
            (model.Username == "user" && model.Password == "user"))
        {
            await loginService.Login(new UserToken() { Token = model.Username });
            navigationManager.NavigateTo("");
            return;
        }

        // ❌ Fallo → aumentar contador
        intentosFallidos++;

        if (intentosFallidos >= 3)
        {
            paginaBloqueada = true;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Página bloqueada",
                Detail = "Has fallado 3 veces. No puedes volver a intentar.",
                Duration = 5000
            });

            return;
        }

        // Error normal
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Error,
            Summary = "Error",
            Detail = $"Usuario o contraseña incorrectos. Intentos restantes: {3 - intentosFallidos}",
            Duration = 4000
        });
    }

    void OnInvalidSubmit(FormInvalidSubmitEventArgs args)
    {
        // No hace nada
    }
}
